{
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=SUPABASE_PROJECT_REF_여기에입력",
        "--read-only"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "SUPABASE_PAT_여기에입력"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "GITHUB_PAT_여기에입력"
      }
    }
  }
}
