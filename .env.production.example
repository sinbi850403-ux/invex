# INVEX 프로덕션 환경변수 — 셀프호스트 Supabase (AWS Lightsail Seoul)
#
# 이 파일을 복사해 `.env.production` 으로 저장 후 실제 값을 채우세요.
# `.env.production`은 Git 미커밋 (.gitignore 확인).
#
# Cloudflare Pages 빌드시 Environment Variables 메뉴에 동일 키/값 등록 필요.
# 설정 → Production → Encrypted

# ============================================================
# 셀프호스트 Supabase (AWS Lightsail Seoul → Cloudflare Tunnel)
# ============================================================
VITE_SUPABASE_URL=https://api.invex.io.kr
VITE_SUPABASE_ANON_KEY=<생성한 ANON_KEY (JWT, role=anon)>

# ============================================================
# 결제
# ============================================================
VITE_TOSS_CLIENT_KEY=live_ck_YOUR_PRODUCTION_KEY
