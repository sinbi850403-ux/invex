# INVEX 환경변수 설정
# 이 파일을 복사해서 `.env` 또는 `.env.production` 으로 저장하세요
# .env* 파일은 절대 Git에 커밋하지 마세요 (이미 .gitignore에 포함됨)

# ============================================================
# Supabase (필수)
#
# 옵션 A — Supabase Cloud (도쿄 리전, 기존 방식)
#   https://app.supabase.com → 프로젝트 → Settings → API
#   VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
#
# 옵션 B — 셀프호스트 Supabase (AWS Lightsail Seoul, 권장)
#   인프라 셋업: db/runbook.md 참고
#   VITE_SUPABASE_URL=https://api.invex.io.kr
#
# 두 옵션 모두 코드 변경 불필요 — 환경변수만 교체하면 됨
# 단, src/supabase-client.js:20-26 의 isValidHttpsUrl() 검증 통과 필수 (HTTPS 강제)
# ============================================================
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# ============================================================
# 토스페이먼츠 (결제 사용 시 필수)
# https://developers.tosspayments.com → 개발자센터 → API 키
# ============================================================
VITE_TOSS_CLIENT_KEY=test_ck_YOUR_TOSS_KEY
